# Deepgram API Key for Speech-to-Text (STT)
# Get your API key at: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Google Cloud Service Account JSON for Text-to-Speech (TTS)
# Provide the absolute path to your Google Cloud service account JSON credentials file
# Get your credentials at: https://console.cloud.google.com/
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your/google-credentials.json
